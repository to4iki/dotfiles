{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '/Users/to4iki/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/to4iki/.orca/agent-hooks/claude-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '/Users/to4iki/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/to4iki/.orca/agent-hooks/claude-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '/Users/to4iki/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/to4iki/.orca/agent-hooks/claude-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '/Users/to4iki/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/to4iki/.orca/agent-hooks/claude-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '/Users/to4iki/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/to4iki/.orca/agent-hooks/claude-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '/Users/to4iki/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/to4iki/.orca/agent-hooks/claude-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '/Users/to4iki/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/to4iki/.orca/agent-hooks/claude-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "language": "japanese",
  "advisorModel": "fable",
  "plansDirectory": "./plans",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
