{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "git-workflow@to4iki-claude-code-plugins": true
  },
  "language": "japanese",
  "plansDirectory": "./plans",
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true
}
