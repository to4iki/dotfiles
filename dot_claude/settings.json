{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git commit:*)",
      "Bash(gh pr:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Read(.env.*)",
      "Read(id_ed25519)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "newest=$(ls -t ./plans/*.md 2>/dev/null | head -1); [ -n \"$newest\" ] && mo \"$newest\" || true",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "git-workflow@to4iki-claude-code-plugins": true
  },
  "language": "japanese",
  "plansDirectory": "./plans",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
